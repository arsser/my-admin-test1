# 生产环境配置示例
# 复制此文件为 .env 并填入实际值

# GitHub 仓库（用于拉取镜像），例如 your-org/your-repo
GITHUB_REPO=your-org/my-admin-test1

# 部署版本（通常由 deploy.sh 自动设置）
VERSION=latest

# Web 端口
WEB_PORT=80
WEB_SSL_PORT=443

# 数据库连接（用于迁移）
# 格式: postgres://user:password@host:port/database?sslmode=disable
DATABASE_URL=postgres://postgres:your_password@localhost:5432/postgres?sslmode=disable

# 可选：Supabase 部署目录（用于 sync-edge-functions.sh）
# SUPABASE_DIR=/path/to/supabase
